# 环境配置示例文件
# 复制此文件为 .env 并根据实际情况修改配置

# 应用基本配置
DEBUG=false
ENVIRONMENT=development

# 数据库配置
DATABASE_URL=mysql+pymysql://username:password@localhost:3306/campus_llm
TEST_DATABASE_URL=mysql+pymysql://username:password@localhost:3306/campus_llm_test

# JWT 安全配置
SECRET_KEY=your-secret-key-here-change-in-production

# Redis 配置
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# 服务器配置
HOST=0.0.0.0
PORT=8000
WORKERS=1

# CORS 跨域配置
# 开发环境：允许具体的localhost端口
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:3001,http://127.0.0.1:5173
# 生产环境：设置为你的前端域名
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# 开发测试（不推荐生产）：允许所有源但禁用凭据
# CORS_ORIGINS=*
# CORS_ALLOW_CREDENTIALS=false

# 是否允许携带凭据（cookies, authorization headers）
# 注意：当设置为 true 时，CORS_ORIGINS 不能使用通配符 "*"
CORS_ALLOW_CREDENTIALS=true

# 文件上传配置
UPLOAD_DIR=./storage/uploads
MAX_FILE_SIZE=52428800  # 50MB in bytes
ALLOWED_EXTENSIONS=pdf,doc,docx,txt,md

# AI 和 RAG 配置
OPENAI_API_KEY=your-openai-api-key-here
CHROMA_DATA_DIR=./data/chroma
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log