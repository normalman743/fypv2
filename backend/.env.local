# 本地开发环境配置
DEBUG=True
ENVIRONMENT=development

# 本地数据库配置 (SQLite)
DATABASE_URL=sqlite:///./local_campus_llm.db
TEST_DATABASE_URL=sqlite:///./test_local.db

# 安全配置
SECRET_KEY=local-dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# OpenAI配置 (本地测试用)
OPENAI_API_KEY=sk-test-local-development-key

# Redis配置 (本地可选)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# 服务器配置
HOST=127.0.0.1
PORT=8000
WORKERS=1

# CORS配置
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# 文件配置
UPLOAD_DIR=./storage/uploads
MAX_FILE_SIZE=52428800
ALLOWED_EXTENSIONS=pdf,doc,docx,txt,md,py,js,html,json,csv

# RAG配置
CHROMA_DATA_DIR=./data/chroma
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200

# 日志配置
LOG_LEVEL=DEBUG
LOG_FILE=./logs/app.log